{
  "buildCommand": "npm run build --prefix wedding-planner-frontend",
  "outputDirectory": "wedding-planner-frontend/dist",
  "installCommand": "npm install --prefix wedding-planner-frontend --legacy-peer-deps",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/((?!moodboard\\.html|assets/|images/).*)",
      "destination": "/index.html"
    }
  ]
}
