# ─── Core ────────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///wedding_planner.db
SECRET_KEY=change-me-in-production
JWT_SECRET_KEY=change-me-in-production

# ─── Multi-tenant / Onboarding ───────────────────────────────────────────────
# Set to "true" to allow couples to self-register at POST /api/auth/couple/register
ALLOW_COUPLE_REGISTRATION=true
# Optional token guard for /api/auth/register (admin bootstrap)
ADMIN_SETUP_TOKEN=

# ─── Stripe (Pillar 2 – Paywall) ─────────────────────────────────────────────
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Create these price IDs in your Stripe dashboard (recurring monthly)
STRIPE_STARTER_PRICE_ID=price_...
STRIPE_PREMIUM_PRICE_ID=price_...

# ─── Anthropic / Claude (Pillar 3 – AI Features) ─────────────────────────────
# Get this from https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# ─── Legacy AI / Token Billing (OpenAI-based venue chat) ─────────────────────
OPENAI_API_KEY=
OPENCLAW_BASE_PRICE_PER_TOKEN=0.001
FREE_PLAN_MONTHLY_TOKENS=100
STANDARD_PLAN_MONTHLY_TOKENS=2000
PREMIUM_PLAN_UNLIMITED=true

# ─── CORS / Server ───────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
VERCEL_URL=
CORS_EXTRA_ORIGINS=

# ─── Optional proxy settings ──────────────────────────────────────────────────
DUCKDUCKGO_PROXY_URL=
HTTP_PROXY=
HTTPS_PROXY=

# ─── Frontend (Vite) ─────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:5000/api

# ─── Deployment flags ────────────────────────────────────────────────────────
# Set to "false" in production when using explicit migrations instead of db.create_all()
AUTO_CREATE_DB=true
# Max upload size in MB
MAX_UPLOAD_MB=25
